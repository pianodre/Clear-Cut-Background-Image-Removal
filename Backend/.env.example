# ClearCut backend — copy to .env and fill in.  cp .env.example .env
# .env is gitignored; never commit real keys.

# --- Photoroom (the background-removal engine) ---
# Your Photoroom API key (Max plan). https://app.photoroom.com/api-dashboard
PHOTOROOM_API_KEY=

# --- Supabase ---
# Project URL and the SECRET service-role key. The service-role key bypasses RLS,
# so it lives only here on the server — never ship it to the frontend.
# Dashboard -> Project Settings -> API -> service_role (secret).
SUPABASE_URL=https://pcpmbdxfquimdddjyvuq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- CORS ---
# Comma-separated list of frontend origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Limits / tuning (safe defaults; override only if needed) ---
# Concurrency for Photoroom calls. 2 is reliable for large images; raising it
# speeds up big batches but can trip transient TLS resets on 10+ MB uploads.
MAX_WORKERS=2
# Credits charged per successfully processed image.
CREDITS_PER_IMAGE=1
# Per-file and per-batch upload caps (bytes) and image-count cap.
MAX_FILE_BYTES=26214400
MAX_TOTAL_UPLOAD_BYTES=524288000
MAX_BATCH_IMAGES=500
# Zip-bomb guards: max entries and max total uncompressed bytes inside a .zip.
MAX_ZIP_ENTRIES=2000
MAX_ZIP_UNCOMPRESSED_BYTES=1073741824
